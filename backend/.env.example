# SiteBox 后端环境变量配置示例
# 复制此文件为 .env 并按需修改（本地开发用）
# Docker 部署时通过 docker-compose.yml 的 environment 段注入

# ─── 服务器配置 ───────────────────────────────────────────────
# 监听端口，默认 3000
PORT=3000

# ─── 数据库配置 ───────────────────────────────────────────────
# SQLite 数据库文件路径（Docker 部署时建议挂载 /app/data 目录）
# Docker 模式：容器内路径保持 /app/data/sitebox.db 即可，通过 volume 持久化
# VPS 裸机模式：可指定任意绝对路径，如 /var/data/sitebox.db
DB_PATH=./data/sitebox.db

# ─── 部署模式 ─────────────────────────────────────────────────
# docker  : Docker 容器 / VPS / NAS 本地部署（使用 better-sqlite3）
# cloudflare : Cloudflare Workers 部署（使用 D1，此变量由 wrangler.toml 注入，无需手动设置）
DEPLOY_MODE=docker
