# SiteBox 后端环境变量配置示例
# 复制此文件为 .env 并按需修改（本地开发用）
# Docker 部署时通过 docker-compose.yml 的 environment 段注入

# ─── 服务器配置 ───────────────────────────────────────────────
# 监听端口，默认 3000
PORT=3000

# ─── 数据库配置 ───────────────────────────────────────────────
# SQLite 数据库文件路径（Docker 部署时建议挂载 /app/data 目录）
# Docker 模式：容器内路径保持 /app/data/db/sitebox.db 即可，通过 volume 持久化
# VPS 裸机模式：可指定任意绝对路径，如 /var/data/db/sitebox.db
DB_PATH=./data/db/sitebox.db

# ─── 部署模式 ─────────────────────────────────────────────────
# docker  : Docker 容器 / VPS / NAS 本地部署（使用 better-sqlite3）
# cloudflare : Cloudflare Workers 部署（使用 D1，此变量由 wrangler.toml 注入，无需手动设置）
DEPLOY_MODE=docker

# ─── GitHub 云端同步配置 ─────────────────────────────────────────
# 用于将数据同步到 GitHub 仓库
# 1. 创建一个 GitHub Personal Access Token (Classic)，并授予 repo 权限
# 2. 填入 Token (ghp_...)
# 3. 填入目标仓库，格式：owner/repo (例如：yourname/sitebox-data)
# 4. 填入文件路径，例如：data/backup.json
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=xxxx/yyyy
GITHUB_PATH=data/backup.json
