{
  "manifest_version": 3,
  "name": "SiteBox",
  "version": "2.0",
  "description": "A browser extension to save website URLs with titles, descriptions, and groups to backend API",
  "action": {
    "default_icon": {
      "16": "icon16.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "CJ.png",
    "32": "icon32.png",
    "128": "icon512.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
